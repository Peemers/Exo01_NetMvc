@model ExoAspNet.Models.Movie

@{
    ViewData["Title"] = "Confirmer la suppression";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-danger">
    <h3>Êtes-vous sur de vouloir supprimer ce film ?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Titre </dt>
        <dd class="col-sm-10">@Model.Titre</dd>
        <dt class="col-sm-2">Genre</dt>
        <dd class="col-sm-10">@Model.Genre</dd>
    </dl>

    <form asp-action="Supprimer" method="post">
        <input type="hidden" asp-for="Id">
        <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
        <a asp-action="Index" class="btn btn-secondary">Annuler</a>
    </form>
</div>

