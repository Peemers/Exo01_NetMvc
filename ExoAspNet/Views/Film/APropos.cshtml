@{
    ViewData["Title"] = "A propos du catalogue";
}

<h1>@ViewData["Title"]</h1>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title"></h5>
        <ul>
            <li>Nombre total de films : <strong>@ViewBag.TotalFilms</strong></li>
        </ul>
        
        @if (TempData["DerniereVisite"] != null)
        {
            <div class=" alert alert-success">
                Derniere Actualisation des statistiques à : @TempData["DerniereVisite"]
            </div>
        }
    </div>
</div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-primary">Retour à la liste complete</a>
</div>